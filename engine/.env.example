# Engine environment variables — copy to .env and fill in values

# Soroban contract deployed on Testnet
CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Relayer keypair (funded on Testnet — never commit the real secret)
RELAYER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Soroban RPC endpoint
RPC_URL=https://soroban-testnet.stellar.org

# "testnet" or "mainnet"
NETWORK=testnet

# Cron schedule (default: every 5 minutes)
CRON_SCHEDULE=*/5 * * * *

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Optional: JSON array of anchor configs
# ANCHORS_JSON=[{"issuer":"G...","assetCode":"USDC","pegCurrency":"USD"}]

# Demo issuer address for single-anchor testnet runs
DEMO_ISSUER_1=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
